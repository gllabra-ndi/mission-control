DATABASE_URL="file:./prisma/dev.db"

# For office-wide production use, switch DATABASE_URL to managed Postgres.
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mission_control?sslmode=require"

AUTH_ENABLED=false
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUTH_BOOTSTRAP_ADMIN_EMAIL=""
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
APP_NAME="Mission Control"

CLICKUP_API_KEY=your_personal_clickup_api_token
CLICKUP_TEAM_ID=your_team_or_workspace_id
CLICKUP_SPACE_ID=optional_space_id
GOOGLE_GENAI_API_KEY=your_google_ai_studio_api_key
GOOGLE_GENAI_MODEL=gemini-1.5-flash

# Mission Control chat is deterministic and read-only.
# It does not call an embedded LLM.

# NetSuite RESTlets (Token-Based Auth / OAuth 1.0a)
NETSUITE_ACCOUNT_ID=your_netsuite_account_id
NETSUITE_CONSUMER_KEY=your_netsuite_consumer_key
NETSUITE_CONSUMER_SECRET=your_netsuite_consumer_secret
NETSUITE_TOKEN_ID=your_netsuite_token_id
NETSUITE_TOKEN_SECRET=your_netsuite_token_secret

# Optional overrides
# NETSUITE_REALM=your_netsuite_account_id
# NETSUITE_BASE_URL=https://<account_id>.restlets.api.netsuite.com
# NETSUITE_RESTLET_PATH=/app/site/hosting/restlet.nl
# NETSUITE_DISCOVERY_SCRIPT_ID=2757
# NETSUITE_DISCOVERY_DEPLOY_ID=1
# NETSUITE_TIME_ENTRY_SCRIPT_ID=2758
# NETSUITE_TIME_ENTRY_DEPLOY_ID=1
# NETSUITE_SYNC_TOKEN=replace-with-a-shared-secret-for-sync-posts

# Runtime
# NODE_ENV=production
